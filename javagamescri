// Spritesheet Preload
const SPRITES = {};
async function preloadSprites() {
  for (const [char, actions] of Object.entries(SPRITEDATA)) {
    SPRITES[char] = {};
    for (const [state, arr] of Object.entries(actions)) {
      SPRITES[char][state] = [];
      for (const src of arr) {
        const img = new window.Image();
        img.src = src;
        await new Promise(r => {img.onload = r;});
        SPRITES[char][state].push(img);
      }
    }
  }
}

// Settings
const FPS = 60, FRAME = 1000 / FPS;

// GLOBAL
let fighters = [];
let keys = {}, keysPrev = {};
let time = 0, shakeTime = 0, flash = 0, floatTexts = [];

// FIGHTER-LOGIK ------------------------------------------------------------------------------------------------------------------------------

function spawnFighters() {
  // Mark (links), Thragg (rechts)
  fighters = [
    mkFighter("Mark", 180, 470, 1, ATK.p1, true),
    mkFighter("Thragg", 780, 470, -1, ATK.thragg)
  ];
}

function mkFighter(name, x, y, dir, ATK, user=false) {
  return {
    name, x, y, vx:0, vy:0, dir, state: S.IDLE, frame:0, t:0, hp:100, ult:100, ultActive:false, controlled:user, ATK,
    combo:0, dead:false, hitstop:0, grabbable:true, aiDelay:0
  };
}

function updateFighter(f, i, opp) {
  // Immunity-Window (ULTIMATE): kein Schaden, kein Knockback, kein Stun, keine Grabs
  if (f.ultActive && (f.state===S.ULTCHARGE || f.state===S.ULTHIT || f.state===S.ULTFINISH)) {
    f.grabbable = false;
  } else {
    f.grabbable = true;
  }

  // Tasten-Update (nur P1)
  if (f.controlled) {
    // ULTIMATE
    if (keys["v"] && !keysPrev["v"] && f.ult===100 && !f.ultActive) {
      // Start ULT sequence
      doUlt(f);
    }
    // ULTHIT: 2xV im ULTCHARGE
    if (f.ultActive && f.state===S.ULTCHARGE && keys["v"] && !keysPrev["v"] && f.t>=2) {
      f.state = S.ULTHIT;
      f.t = f.frame = 0;
    }
  }

  // State-Flow
  switch (f.state) {
    case S.ULTCHARGE:
      if(f.t===0) spawnAura(f);
      if(f.t >= ATK.ultCharge.sp) {
        // Recovery (Immun bleibt)
        if(f.t >= ATK.ultCharge.sp + ATK.ultCharge.rc) {
          // Wenn kein Hit, Autotransition zu ULTFINISH
          if (f.state===S.ULTCHARGE) {
            f.state = S.ULTFINISH; f.t = f.frame = 0;
          }
        }
      }
      break;
    case S.ULTHIT:
      if(f.t===0) { screenShake(12); spawnHitBurst(f); }
      // Multi-Hit-Window: alle 2 Frames (3x)
      if(f.t < ATK.ultHit.ac && f.t%2===0) {
        doUltHitbox(f, opp, i);
      }
      if(f.t >= ATK.ultHit.sp + ATK.ultHit.ac + ATK.ultHit.rc) {
        f.state = S.ULTFINISH; f.t = f.frame = 0;
      }
      break;
    case S.ULTFINISH:
      // Finish-Text & Pose
      if(f.t===0) {
        spawnFloatText("ULTIMATE!",f.x+f.dir*48,f.y-56,"#fff82f");
      }
      if(f.t >= 45) {
        f.ult = 0; // Reset Ult-Bar
        f.ultActive = false;
        f.state = S.IDLE; f.frame = f.t = 0;
      }
      break;
    default:
      // Normal-States (Jump, Walk, Kick, etc.) würde hier stehen...
      break;
  }

  f.t++;
}

// DAMAGE HANDLING (Ultimate Immunity)
function tryHit(target, dmg, kx, ky, unblk=false) {
  // ULTIMATE Immunity
  if(target.ultActive && (target.state===S.ULTCHARGE||target.state===S.ULTHIT||target.state===S.ULTFINISH)) return;
  target.hp = Math.max(0, target.hp - dmg);
  target.vx += kx||0;
  target.vy += ky||0;
  if (dmg>0) spawnFloatText("-"+dmg,target.x,target.y-48,"#FF3939");
}

// == INPUT BINDING ==
window.addEventListener("keydown", e=>{keys[e.key.toLowerCase()]=true;});
window.addEventListener("keyup", e=>{keys[e.key.toLowerCase()]=false;});

// == ULTIMATE LOGIC ==
function doUlt(f) {
  f.state = S.ULTCHARGE; f.frame = f.t = 0;
  f.ultActive = true;
}

// == ULTIMATE Hitbox Effect ==
function doUltHitbox(f, opp, idx) {
  // Massive Multi-Hit
  let atk = (f.name==="Thragg") ? ATK.thragg.ultHit : ATK.p1.ultHit;
  tryHit(opp, atk.dmg, atk.kx*f.dir, atk.ky, true);
  // Stun/Flinch
  opp.state = S.HIT; opp.t = 0;
}

// == VFX ==

function spawnAura(f) {
  // Gold Partikel + Glow um Fighter für ULTCHARGE
  floatTexts.push({txt:"���",x:f.x,y:f.y-64,col:"#ffe75e",vy:-1,life:24});
}

function screenShake(frames) {
  shakeTime = Math.max(shakeTime, frames);
}pt

function spawnHitBurst(f) {
  floatTexts.push({txt:"★",x:f.x+f.dir*36,y:f.y-36,col:"#fff",vy:-2,life:20});
  flash = 10;
}

function spawnFloatText(txt,x,y,col="#fff",vy=-1,life=32) {
  floatTexts.push({txt,x,y,col,vy,life});
}

// == DRAW ==

function drawFighter(f) {
  let spr;
  if(f.state===S.ULTCHARGE) {
    spr = SPRITES[f.name].ultCharge[(f.frame/2|0)%6];
  } else if(f.state===S.ULTHIT) {
    spr = SPRITES[f.name].ultHit[(f.frame/2|0)%2];
  } else if(f.state===S.ULTFINISH) {
    spr = SPRITES[f.name].ultFinish[0];
  } else {
    // Normale Sprites z.B. idle
    spr = SPRITES[f.name]["idle"][0];
  }
  if (spr) ctx.drawImage(spr, f.x-48, f.y-96, 96, 96);
}

function drawUI(f, i) {
  let color = i===0?"#44d782":"#d72943";
  // Ult-Bar
  ctx.fillStyle="#252525"; ctx.fillRect(f.x-40,f.y+12,92,10);
  ctx.fillStyle=f.ultActive?"#ffe75e":color;
  ctx.fillRect(f.x-40,f.y+12,Math.floor(f.ult*0.92),10);
  ctx.strokeStyle="#333"; ctx.strokeRect(f.x-40,f.y+12,92,10);
  // HP
  ctx.fillStyle=color; ctx.fillRect(f.x-40,f.y+26,Math.floor(f.hp*0.92),8);
}

function drawFX() {
  floatTexts.forEach(t=> {
    ctx.save();
    ctx.globalAlpha=Math.max(0,t.life/32);
    ctx.fillStyle=t.col;ctx.font="bold 32px monospace";
    ctx.fillText(t.txt,t.x,t.y);
    ctx.restore();
    t.y+=t.vy; t.life--;
  });
  floatTexts = floatTexts.filter(t=>t.life>0);
}

function drawFlashAndShake() {
  if(flash>0) {
    ctx.save();ctx.globalAlpha=0.25;
    ctx.fillStyle="#fff8a2";ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.restore();
    flash--;
  }
  if(shakeTime>0) {
    let dx=(Math.random()-0.5)*12,dy=(Math.random()-0.5)*8;
    ctx.setTransform(1,0,0,1,dx,dy); shakeTime--;
  } else ctx.setTransform(1,0,0,1,0,0);
}

// == GAMELOOP ==

function gameloop() {
  ctx.clearRect(0,0,canvas.width,canvas.height);
  drawFlashAndShake();
  // Fighters
  for(let i=0;i<2;i++) {
    drawFighter(fighters[i]);
    drawUI(fighters[i], i);
    updateFighter(fighters[i], i, fighters[1-i]);
  }
  drawFX();
  // UI
  uiDiv.innerText = `ULT-BAR: [${fighters[0].ult}${fighters[0].ultActive?"/IMMUNE":""}]   Thragg ULT: [${fighters[1].ult}]   STATE: ${Object.keys(S).find(k=>S[k]===fighters[0].state)}`;
  time++;
  Object.assign(keysPrev, keys);
  requestAnimationFrame(gameloop);
}

// == START ==
(async() => {
  await preloadSprites();
  spawnFighters();
  gameloop();
})();
