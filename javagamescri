const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");
const uiDiv = document.getElementById("ui");

const S = { // State-Enum
  IDLE: 0, WALK: 1, JUMP: 2, PUNCH: 3, KICK: 4, GRAB: 5,
  HIT: 6, DOWN: 7, DEAD: 8, BLOCK: 9, 
  ULTCHARGE: 10, ULTHIT: 11, ULTFINISH: 12
};

const ATK = {
  p1: {
    punch: {sp:6,ac:3,rc:8,dmg:8,kx:11,ky:-6},
    kick: {sp:8,ac:6,rc:10,dmg:12,kx:14,ky:-9},
    ultCharge: {sp:12,ac:0,rc:30,dmg:0},
    ultHit: {sp:8,ac:6,rc:20,dmg:35,kx:25,ky:-25,unblockable:true}
  },
  thragg: {
    punch: {sp:5,ac:3,rc:6,dmg:12,kx:15,ky:-8},
    ultCharge: {sp:11,ac:0,rc:25,dmg:0},
    ultHit: {sp:7,ac:6,rc:18,dmg:45,kx:30,ky:-30,unblockable:true}
  }
};

